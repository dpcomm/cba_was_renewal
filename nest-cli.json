{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "src",
  "sourceRoot": "src",
  "defaultProject": "api",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "infrastructure/mail/templates/**/*",
        "outDir": "dist/src"
      },
      {
        "include": "infrastructure/mail/assets/**/*",
        "outDir": "dist/src"
      }
    ]
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "src",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "email-worker": {
      "type": "application",
      "root": "apps/email-worker",
      "entryFile": "main",
      "sourceRoot": "apps/email-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/email-worker/tsconfig.app.json"
      }
    },
    "push-worker": {
      "type": "application",
      "root": "apps/push-worker",
      "entryFile": "main",
      "sourceRoot": "apps/push-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/push-worker/tsconfig.app.json"
      }
    }
  }
}
